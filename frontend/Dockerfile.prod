# Production Dockerfile for APEX.BUILD Frontend
# Multi-stage build for optimized production image

# Stage 1: Build
FROM node:18-alpine AS builder

ARG VITE_API_URL=https://apex-backend-5ypy.onrender.com/api/v1
ARG VITE_WS_URL=wss://apex-backend-5ypy.onrender.com/ws

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install full dependency graph so Vite and other build-time tooling are available
RUN npm ci --silent

# Copy source code
COPY . .

# Build the application
ENV NODE_ENV=production
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_WS_URL=${VITE_WS_URL}
RUN npm run build

# Stage 2: Production
FROM nginx:alpine AS production

# Install security updates
RUN apk update && apk upgrade && apk add --no-cache curl

# Remove default nginx config
RUN rm -rf /usr/share/nginx/html/*

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy custom nginx configuration
COPY nginx.conf /etc/nginx/nginx.conf
COPY docker-entrypoint.sh /docker-entrypoint.sh

# Create non-root user for nginx
RUN addgroup -g 1001 -S nginx-custom && \
    adduser -S -D -H -u 1001 -h /var/cache/nginx -s /sbin/nologin -G nginx-custom -g nginx-custom nginx-custom

# Create required directories with proper permissions
RUN chmod +x /docker-entrypoint.sh && \
    mkdir -p /var/cache/nginx /var/log/nginx /var/run/nginx /run && \
    chown -R nginx-custom:nginx-custom /var/cache/nginx /var/log/nginx /var/run/nginx /run /usr/share/nginx/html /etc/nginx /etc/nginx/conf.d && \
    touch /run/nginx.pid && \
    chown nginx-custom:nginx-custom /run/nginx.pid

# Copy SSL certificates (will be mounted in production)
RUN mkdir -p /etc/nginx/certs

# Switch to non-root user
USER nginx-custom

# Runtime defaults
ENV PORT=80
ENV NODE_ENV=production

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD sh -c 'curl -f "http://localhost:${PORT:-80}/health" || exit 1'

# Expose ports
EXPOSE 80 443

# Start nginx through the shared runtime entrypoint
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
